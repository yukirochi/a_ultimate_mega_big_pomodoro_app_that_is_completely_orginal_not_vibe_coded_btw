{
  "name": "focus-bomb",
  "version": "1.0.0",
  "description": "A focused Pomodoro timer for Ubuntu",
  "main": "src/main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.focusbomb.app",
    "productName": "Constant",
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": []
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  }
}
